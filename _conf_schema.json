{
    "relationship_aliases": {
        "title": "用户称呼映射",
        "description": "本地用户称呼映射",
        "type": "list",
        "items": {
            "type": "string"
        },
        "default": [],
        "hint": "可选配置，用于补充平台无法稳定获取的用户称呼，会影响聊天记忆、邀约、备忘录、参考私聊、MemOS 和面板展示。格式：用户标识/会话标识:称呼，例如 123456:用户称呼 或 o2xxxx@im.wechat:用户称呼。QQ 未配置时会尝试获取备注、昵称；个人微信无法稳定获取真实昵称，建议在这里配置称呼。"
    },
    "rhythm_config": {
        "description": "生活背景基础",
        "type": "object",
        "hint": "设置每日生活背景生成时间、历史参考和基础生成模型。",
        "items": {
            "schedule_time": {
                "description": "生成时间",
                "type": "string",
                "default": "07:00",
                "hint": "每日生活背景生成时间，使用 24 小时制，例如 07:00。"
            },
            "history_days": {
                "description": "参考天数",
                "type": "int",
                "default": 3,
                "hint": "生成日程时参考的历史天数"
            },
            "reference_groups": {
                "title": "参考群聊",
                "description": "生成日程时参考的群聊",
                "type": "list",
                "items": {
                    "type": "string"
                },
                "default": [],
                "hint": "填入群号；个人微信 weixin_oc 仅支持私聊，不支持群聊。"
            },
            "reference_users": {
                "title": "参考私聊",
                "description": "生成日程时参考的私聊",
                "type": "list",
                "items": {
                    "type": "string"
                },
                "default": [],
                "hint": "填入 QQ 号、个人微信 openid/会话标识，或完整 UMO，例如 123456、o2xxxx@im.wechat、weixin_oc:FriendMessage:o2xxxx@im.wechat。个人微信历史来自已保存的消息/会话历史。"
            },
            "history_hours": {
                "description": "历史回溯时间(小时)",
                "type": "int",
                "default": 24,
                "slider": {
                    "min": 0,
                    "max": 168,
                    "step": 1
                },
                "hint": "回溯过去N小时的聊天记录"
            },
            "history_max_count": {
                "description": "最大参考条数",
                "type": "int",
                "default": 50,
                "slider": {
                    "min": 0,
                    "max": 200,
                    "step": 1
                },
                "hint": "每个会话最多参考的消息条数"
            },
            "llm_provider": {
                "description": "日常生活",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "指定日程生成、周计划生成和周模板生成使用的模型；留空则使用当前默认模型"
            }
        }
    },
    "weather_awareness": {
        "description": "天气",
        "type": "object",
        "hint": "配置天气接口，让日程与天气挂钩。",
        "items": {
            "api_key": {
                "description": "柠柚接口密钥",
                "type": "string",
                "default": "",
                "hint": "从 https://api.nycnm.cn 获取接口密钥。"
            },
            "default_city": {
                "description": "默认城市",
                "type": "string",
                "default": "",
                "hint": "如果无法从人设提取城市，则使用此城市"
            },
            "aware_outfit": {
                "description": "影响穿搭",
                "type": "bool",
                "default": true,
                "hint": "根据天气指数（生活指数）调整穿搭建议"
            },
            "aware_activity": {
                "description": "影响活动",
                "type": "bool",
                "default": true,
                "hint": "根据天气（如下雨、生活指数）调整活动安排"
            }
        }
    },
    "outfit_config": {
        "description": "服装",
        "type": "object",
        "hint": "单独配置实时穿搭判断使用的模型。完整日程生成中的穿搭仍跟随生成模型。",
        "items": {
            "provider": {
                "description": "百变穿搭",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "指定自动穿搭判断和手动穿搭更新使用的模型；留空则使用当前默认模型"
            }
        }
    },
    "state_config": {
        "description": "实时状态",
        "type": "object",
        "hint": "配置体力、心情、忙碌度、社交意愿、睡眠质量、静默时段，以及后台状态与穿搭巡检。",
        "items": {
            "enabled": {
                "description": "启用实时状态",
                "type": "bool",
                "default": true,
                "hint": "开启后每日生成状态，并按刷新间隔在后台巡检当前状态；聊天和邀约也会按同一间隔触发状态更新。"
            },
            "provider": {
                "description": "状态更新",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "单独指定实时状态更新使用的模型；留空则使用当前默认模型"
            },
            "refresh_minutes": {
                "description": "刷新间隔(分钟)",
                "type": "int",
                "default": 30,
                "slider": {
                    "min": 5,
                    "max": 240,
                    "step": 5
                },
                "hint": "聊天触发状态刷新和后台巡检共用该间隔；到达间隔后会刷新实时状态，聊天与邀约也会触发状态更新。"
            },
            "quiet_hours": {
                "description": "静默时段",
                "type": "string",
                "default": "00:00-06:30",
                "hint": "可填写 00:00-06:30 这类时间段；静默时段内只会跳过后台状态巡检，聊天与邀约仍会按刷新间隔触发状态更新。留空表示不排除任何时段。"
            }
        }
    },
    "invite_config": {
        "description": "邀约",
        "type": "object",
        "hint": "单独配置邀约接受、拒绝和改约判断使用的模型。",
        "items": {
            "provider": {
                "description": "盛情邀约",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "指定邀约处理使用的模型；留空则使用当前默认模型"
            }
        }
    },
    "commitment_config": {
        "description": "约定追踪",
        "type": "object",
        "hint": "从聊天中沉淀未来承诺、提醒和下次续聊事项，到期后影响生活背景生成。",
        "items": {
            "provider": {
                "description": "约定识别",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "单独指定承诺抽取使用的模型；留空则使用当前默认模型"
            },
            "min_confidence": {
                "description": "自动保存阈值",
                "type": "float",
                "default": 0.7,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "模型判断置信度低于该值时不自动保存"
            }
        }
    },
    "memory_config": {
        "description": "记忆",
        "type": "object",
        "hint": "把普通聊天提炼成关系记忆、聊天摘要，并在生成/注入时只挑相关内容。",
        "items": {
            "provider": {
                "description": "记忆提炼",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "单独指定聊天记忆提炼使用的模型；留空则使用当前默认模型"
            },
            "min_message_length": {
                "description": "最短消息长度",
                "type": "int",
                "default": 8,
                "slider": {
                    "min": 1,
                    "max": 200,
                    "step": 1
                },
                "hint": "低于该长度的消息不会自动提炼，避免保存寒暄和短表情"
            },
            "max_generation_items": {
                "description": "生成参考条数",
                "type": "int",
                "default": 8,
                "slider": {
                    "min": 0,
                    "max": 30,
                    "step": 1
                },
                "hint": "生成日程时最多注入多少条聊天记忆摘要"
            },
            "max_injection_items": {
                "description": "聊天注入条数",
                "type": "int",
                "default": 5,
                "slider": {
                    "min": 0,
                    "max": 20,
                    "step": 1
                },
                "hint": "普通聊天隐藏上下文中最多注入多少条相关聊天记忆摘要"
            }
        }
    },
    "memos_config": {
        "description": "MemOS 记忆",
        "type": "object",
        "hint": "连接 MemOS 托管服务，把外部长期事实和偏好作为隐藏参考。默认只检索不写入；精选同步开启后，仅同步本插件判断值得长期复用的摘要、偏好和纠错。",
        "items": {
            "enabled": {
                "description": "启用 MemOS",
                "type": "bool",
                "default": false,
                "hint": "开启后聊天前会短超时检索 MemOS 外部长期记忆，失败不会影响正常回复。"
            },
            "base_url": {
                "description": "服务地址",
                "type": "string",
                "default": "https://memos.memtensor.cn/api/openmem/v1",
                "hint": "MemOS 托管服务 API 地址，末尾不需要斜杠。"
            },
            "api_key": {
                "description": "接口密钥",
                "type": "string",
                "default": "",
                "hint": "MemOS 托管服务 Token。留空时不会请求外部记忆。"
            },
            "timeout_seconds": {
                "description": "请求超时(秒)",
                "type": "float",
                "default": 15,
                "slider": {
                    "min": 0.5,
                    "max": 30,
                    "step": 0.5
                },
                "hint": "MemOS 后台同步和普通请求的单次超时；聊天回复前的注入等待由下方单独控制，不会跟着变慢。"
            },
            "injection_timeout_seconds": {
                "description": "注入等待(秒)",
                "type": "float",
                "default": 0.8,
                "slider": {
                    "min": 0.2,
                    "max": 5,
                    "step": 0.1
                },
                "hint": "聊天回复前最多等待 MemOS 检索多久；超时会跳过本轮外部记忆，不影响正常回复。"
            },
            "memory_limit_number": {
                "description": "事实记忆条数",
                "type": "int",
                "default": 5,
                "slider": {
                    "min": 1,
                    "max": 20,
                    "step": 1
                },
                "hint": "每次最多检索多少条事实记忆。"
            },
            "preference_limit_number": {
                "description": "偏好记忆条数",
                "type": "int",
                "default": 4,
                "slider": {
                    "min": 0,
                    "max": 20,
                    "step": 1
                },
                "hint": "每次最多检索多少条偏好记忆。"
            },
            "max_context_items": {
                "description": "注入条数",
                "type": "int",
                "default": 6,
                "slider": {
                    "min": 1,
                    "max": 20,
                    "step": 1
                },
                "hint": "外部记忆参考最多写入隐藏上下文多少条。"
            },
            "max_context_chars": {
                "description": "注入字数",
                "type": "int",
                "default": 700,
                "slider": {
                    "min": 120,
                    "max": 3000,
                    "step": 20
                },
                "hint": "限制外部记忆参考总长度，避免提示词变胖。"
            },
            "include_preference": {
                "description": "检索偏好",
                "type": "bool",
                "default": true,
                "hint": "开启后同时检索 MemOS 的偏好记忆。"
            },
            "sync_selected_memory": {
                "description": "同步精选记忆",
                "type": "bool",
                "default": false,
                "hint": "开启后，本插件判断值得长期复用的聊天摘要、关系点和偏好会异步同步到 MemOS。不会同步每轮聊天。"
            },
            "sync_corrections": {
                "description": "同步记忆纠错",
                "type": "bool",
                "default": true,
                "hint": "开启后，用户明确纠正并被本插件采纳的记忆纠错会同步给 MemOS。"
            }
        }
    },
    "response_gate_config": {
        "description": "随心回复",
        "type": "object",
        "hint": "普通聊天到来时先判断当前适不适合回复：结合群聊/私聊、@/引用、消息结构、实时状态和近期节奏决定是否交给默认 LLM；不回复时仍会记录上下文、图片识别和记忆沉淀。",
        "items": {
            "enabled": {
                "description": "启用随心回复",
                "type": "bool",
                "default": true,
                "hint": "开启后普通聊天不再每条都硬回；@、唤醒、引用和命令仍会直接处理。"
            },
            "group_talk_frequency": {
                "description": "群聊回复意愿",
                "type": "float",
                "default": 0.45,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "群聊普通消息进入默认回复的基础意愿。数值越低越安静，仍会结合实时状态、消息结构和近期节奏动态调整。"
            },
            "private_talk_frequency": {
                "description": "私聊回复意愿",
                "type": "float",
                "default": 0.65,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "私聊普通消息进入默认回复的基础意愿。私聊不再因为 AstrBot 自动唤醒就必回，会结合困倦、忙碌、刚回复过或对方可能连发等状态观察。"
            },
            "min_interval_seconds": {
                "description": "最短回复间隔(秒)",
                "type": "int",
                "default": 12,
                "slider": {
                    "min": 0,
                    "max": 300,
                    "step": 1
                },
                "hint": "同一会话刚回复过时，短时间内降低再次进入默认回复的倾向，避免连续抢话。"
            },
            "no_reply_backoff_seconds": {
                "description": "安静观察基准(秒)",
                "type": "int",
                "default": 25,
                "slider": {
                    "min": 0,
                    "max": 600,
                    "step": 5
                },
                "hint": "连续几次判断不回复后，下次普通消息先短暂安静观察的基准时间。0 表示不使用安静观察。"
            },
            "no_reply_backoff_cap_seconds": {
                "description": "安静观察上限(秒)",
                "type": "int",
                "default": 180,
                "slider": {
                    "min": 0,
                    "max": 1800,
                    "step": 10
                },
                "hint": "连续观察时保持安静的最长时间。"
            },
            "no_reply_backoff_start_count": {
                "description": "安静观察起点",
                "type": "int",
                "default": 2,
                "slider": {
                    "min": 1,
                    "max": 20,
                    "step": 1
                },
                "hint": "连续多少次不回复后开始进入安静观察。"
            },
            "bypass_pending_count": {
                "description": "绕过消息数",
                "type": "int",
                "default": 5,
                "slider": {
                    "min": 0,
                    "max": 50,
                    "step": 1
                },
                "hint": "同一会话短时间积累到多少条待看消息时，绕过安静观察并提高回复意愿。0 表示不按消息数绕过。"
            },
            "media_only_group_frequency": {
                "description": "群聊纯媒体回复意愿",
                "type": "float",
                "default": 0.2,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "群聊只有图片、语音、视频或文件而没有文字时，进入默认回复的基础意愿。后台视觉识别仍会正常进行。"
            }
        }
    },
    "proactive_config": {
        "description": "闲时回复",
        "type": "object",
        "hint": "让角色在会话沉默一段时间后，根据生活状态、注意力开放度、会话氛围、关系印象和近期记忆自主判断是否自然续一句。默认关闭，开启后会增加额外模型调用。",
        "items": {
            "enabled": {
                "description": "启用闲时回复",
                "type": "bool",
                "default": false,
                "hint": "开启后只记录普通会话的活跃度，不拦截命令和正常聊天；后台等会话安静后再由语言模型裁定是否自然续一句。"
            },
            "group_enabled": {
                "description": "群聊闲时",
                "type": "bool",
                "default": true,
                "hint": "允许群聊在沉默一段时间后，由语言模型判断是否自然补一句。"
            },
            "private_enabled": {
                "description": "私聊闲时",
                "type": "bool",
                "default": true,
                "hint": "允许私聊在沉默一段时间后，由语言模型判断是否自然续一句；不会拦截正常聊天回复。"
            },
            "provider": {
                "description": "闲时回复",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "单独指定闲时回复裁定和短回复生成使用的模型；留空则使用当前默认模型"
            },
            "talk_frequency": {
                "description": "闲时频率",
                "type": "float",
                "default": 0.35,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "群聊沉默后的闲时发言倾向。数值越高越愿意自然参与，仍由语言模型结合状态和群聊氛围裁定，不是概率硬触发。"
            },
            "private_talk_frequency": {
                "description": "私聊频率",
                "type": "float",
                "default": 0.55,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "私聊沉默后的闲时回应倾向。数值越高越愿意自然回应，仍由语言模型结合关系、状态和消息内容裁定。"
            },
            "idle_minutes": {
                "description": "群聊沉默(分钟)",
                "type": "int",
                "default": 30,
                "slider": {
                    "min": 1,
                    "max": 240,
                    "step": 1
                },
                "hint": "同一个群聊最后一条可参考消息后，至少安静多久才允许进入闲时回复裁定。"
            },
            "private_idle_minutes": {
                "description": "私聊沉默(分钟)",
                "type": "int",
                "default": 60,
                "slider": {
                    "min": 5,
                    "max": 1440,
                    "step": 5
                },
                "hint": "同一个私聊最后一条可参考消息后，至少安静多久才允许进入闲时回复裁定。"
            },
            "cooldown_minutes": {
                "description": "群聊冷却(分钟)",
                "type": "int",
                "default": 20,
                "slider": {
                    "min": 1,
                    "max": 240,
                    "step": 1
                },
                "hint": "同一个群聊闲时回复后的最短间隔，避免连续抢话。"
            },
            "private_cooldown_minutes": {
                "description": "私聊冷却(分钟)",
                "type": "int",
                "default": 8,
                "slider": {
                    "min": 1,
                    "max": 240,
                    "step": 1
                },
                "hint": "同一个私聊会话闲时回应后的最短间隔，避免连续打扰。"
            },
            "min_message_length": {
                "description": "最短消息长度",
                "type": "int",
                "default": 4,
                "slider": {
                    "min": 1,
                    "max": 200,
                    "step": 1
                },
                "hint": "低于该长度的普通群聊/私聊消息不会进入闲时回复候选。"
            },
            "min_confidence": {
                "description": "回复置信度",
                "type": "float",
                "default": 0.72,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.05
                },
                "hint": "模型裁定置信度低于该值时不发送闲时回复。"
            },
            "max_reply_length": {
                "description": "回复长度上限",
                "type": "int",
                "default": 80,
                "slider": {
                    "min": 10,
                    "max": 300,
                    "step": 10
                },
                "hint": "闲时回复应保持短句，避免像正式长回复。"
            },
            "private_revisit_enabled": {
                "description": "私聊回访",
